# URL pública del proyecto Supabase (Project Settings → API).
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key (Project Settings → API). Segura para exponer al cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings → API). NUNCA exponer al cliente.
# Usar solo en route handlers / server actions.
SUPABASE_SERVICE_ROLE_KEY=

# URL base de la app — en dev http://localhost:3000, en prod la URL de Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000
